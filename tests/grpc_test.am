// Unit tests for the gRPC core — framing round-trip (binary-safe),
// big-endian length, path helpers, status codes, and server dispatch
// (registered handler, unknown method -> UNIMPLEMENTED). Network-free.

namespace Tests

import Amalgame.Collections
import Amalgame.String
import Amalgame.Net.Grpc

public class Program {
    static List<int> bytes(int a, int b, int c) {
        let l = new List<int>()
        l.Add(a)
        l.Add(b)
        l.Add(c)
        return l
    }
    static bool listEq(List<int> a, List<int> b) {
        if (a.Count() != b.Count()) { return false }
        var i: int = 0
        while (i < a.Count()) {
            if (a.Get(i) != b.Get(i)) { return false }
            i = i + 1
        }
        return true
    }

    public static void Main(string[] args) {
        Console.WriteLine("amalgame-net-grpc — core tests")
        var pass: int = 0
        var fail: int = 0

        // ── 1. Frame encode: header layout + big-endian length ───
        // 3-byte message → flag 0 + length 00 00 00 03 + payload.
        let msg = Program.bytes(0, 255, 0)         // includes NUL + 0xFF
        let fr = GrpcFrame.Encode(msg)
        let hdrOk: bool = fr.Count() == 8
            && fr.Get(0) == 0
            && fr.Get(1) == 0 && fr.Get(2) == 0 && fr.Get(3) == 0 && fr.Get(4) == 3
            && fr.Get(5) == 0 && fr.Get(6) == 255 && fr.Get(7) == 0
        if (hdrOk) {
            Console.WriteLine("[PASS] frame header: flag 0 + BE length + binary-safe payload")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] frame header wrong (len " + String_FromInt(fr.Count()) + ")")
            fail = fail + 1
        }

        // ── 2. Multi-frame decode round-trip ─────────────────────
        let m1 = Program.bytes(0, 1, 2)
        let m2 = Program.bytes(255, 0, 128)
        let buf = new List<int>()
        let e1 = GrpcFrame.Encode(m1)
        let e2 = GrpcFrame.Encode(m2)
        var k: int = 0
        while (k < e1.Count()) { buf.Add(e1.Get(k)); k = k + 1 }
        k = 0
        while (k < e2.Count()) { buf.Add(e2.Get(k)); k = k + 1 }
        let rdr = GrpcFrameReader.New(buf)
        var got1: List<int> = new List<int>()
        var got2: List<int> = new List<int>()
        var count: int = 0
        if (rdr.HasNext()) { got1 = rdr.Next(); count = count + 1 }
        if (rdr.HasNext()) { got2 = rdr.Next(); count = count + 1 }
        let moreAfter: bool = rdr.HasNext()
        if (count == 2 && !moreAfter && Program.listEq(m1, got1) && Program.listEq(m2, got2)) {
            Console.WriteLine("[PASS] multi-frame decode round-trip (binary-exact)")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] multi-frame decode (count " + String_FromInt(count) + ")")
            fail = fail + 1
        }

        // ── 3. Large length (300 bytes) big-endian correctness ───
        let big = new List<int>()
        var z: int = 0
        while (z < 300) { big.Add(z & 255); z = z + 1 }
        let ebig = GrpcFrame.Encode(big)
        // 300 = 0x0000012C → length bytes 00 00 01 2C
        let lenOk: bool = ebig.Get(1) == 0 && ebig.Get(2) == 0 && ebig.Get(3) == 1 && ebig.Get(4) == 44
        let rbig = GrpcFrameReader.New(ebig)
        var dbig: List<int> = new List<int>()
        if (rbig.HasNext()) { dbig = rbig.Next() }
        if (lenOk && Program.listEq(big, dbig)) {
            Console.WriteLine("[PASS] 300-byte frame: BE length 00 00 01 2C + exact round-trip")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] large frame length/round-trip")
            fail = fail + 1
        }

        // ── 4. Path helper + status codes ────────────────────────
        let p: string = GrpcPath.Make("greeter.Greeter", "SayHello")
        if (p == "/greeter.Greeter/SayHello" && GrpcStatus.Ok() == 0 && GrpcStatus.Unimplemented() == 12 && GrpcStatus.NotFound() == 5) {
            Console.WriteLine("[PASS] path build + status code constants")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] path/status: " + p)
            fail = fail + 1
        }

        // ── 5. Server dispatch: registered handler echoes ────────
        // echo handler: reply body = request body (single-expression closure)
        let srv = GrpcServer.New().Register("/echo.Echo/Ping",
            (req: GrpcRequest) => GrpcReply.Ok(req.Body))
        let reqMsg = Program.bytes(7, 0, 9)          // NUL inside
        let reqFrame = GrpcFrame.Encode(reqMsg)
        let reply = srv.Dispatch("/echo.Echo/Ping", reqFrame)
        if (reply.IsOk() && Program.listEq(reqMsg, reply.Body)) {
            Console.WriteLine("[PASS] dispatch routes to handler + unframes request (binary-safe)")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] dispatch handler (status " + String_FromInt(reply.Status) + ")")
            fail = fail + 1
        }

        // ── 6. Unknown method → UNIMPLEMENTED ────────────────────
        let r404 = srv.Dispatch("/nope.No/Method", GrpcFrame.Encode(Program.bytes(1, 2, 3)))
        if (!r404.IsOk() && r404.Status == GrpcStatus.Unimplemented()) {
            Console.WriteLine("[PASS] unknown method → UNIMPLEMENTED (12)")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] unknown method status " + String_FromInt(r404.Status))
            fail = fail + 1
        }

        // ── 7. ResponseFrame re-wraps the reply body ─────────────
        let rf = GrpcServer.ResponseFrame(reply)
        let rrdr = GrpcFrameReader.New(rf)
        var rback: List<int> = new List<int>()
        if (rrdr.HasNext()) { rback = rrdr.Next() }
        if (Program.listEq(reply.Body, rback)) {
            Console.WriteLine("[PASS] ResponseFrame round-trips the reply body")
            pass = pass + 1
        } else {
            Console.WriteLine("[FAIL] ResponseFrame mismatch")
            fail = fail + 1
        }

        Console.WriteLine("")
        Console.WriteLine("Summary: " + String_FromInt(pass) + " passed, " + String_FromInt(fail) + " failed")
    }
}
